const log = require('electron-log');

// Lazy-load electron-updater: only providers that actually use it will trigger
// the require, so apps configured with a custom HTTP provider start fine even
// if electron-updater is absent from the package.
function getAutoUpdater() {
  return require('electron-updater').autoUpdater;
}

/**
 * Base class for Update Providers
 */
class UpdateProvider {
  async check() { throw new Error('Not implemented'); }
  async download() { throw new Error('Not implemented'); }
  async getLatest() { throw new Error('Not implemented'); }
}

/**
 * GitHub Releases Provider
 */
class GitHubProvider extends UpdateProvider {
  async check() {
    log.info('Checking for updates via GitHub...');
    return await getAutoUpdater().checkForUpdates();
  }
  async download() {
    return await getAutoUpdater().downloadUpdate();
  }
  async getLatest() {
    return await getAutoUpdater().getLatestVersion();
  }
}

/**
 * Custom HTTP Provider
 */
class CustomHTTPProvider extends UpdateProvider {
  constructor(url) {
    super();
    this.url = url;
  }

  async check() {
    log.info(`Checking for updates via ${this.url}...`);
    try {
      const response = await fetch(`${this.url}/latest.json`);
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

      const data = await response.json();
      const currentVersion = require('./package.json').version;

      if (data.version !== currentVersion) {
        log.info(`New version available: ${data.version}`);
        return { updateAvailable: true, version: data.version, releaseNotes: data.releaseNotes };
      }

      return { updateAvailable: false };
    } catch (e) {
      log.error('Custom HTTP update check failed:', e);
      return { updateAvailable: false, error: e.message };
    }
  }

  async download() {
    log.info('Downloading update from custom provider...');
  }

  async getLatest() {
    try {
      const response = await fetch(`${this.url}/latest.json`);
      const data = await response.json();
      return data.version;
    } catch (e) {
      return 'Unknown';
    }
  }
}

const PROVIDERS = {
  github: GitHubProvider,
  custom: CustomHTTPProvider,
};

function createUpdater(config) {
  const ProviderClass = PROVIDERS[config.updater.provider] || PROVIDERS.custom;
  return new ProviderClass(config.updater.url);
}

module.exports = { createUpdater };
